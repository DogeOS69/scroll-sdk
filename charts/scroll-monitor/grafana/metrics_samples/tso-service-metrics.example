# HELP tso_core_registered_signers_count Number of currently registered signers in the TSO
# TYPE tso_core_registered_signers_count gauge
tso_core_registered_signers_count 3
# HELP tso_core_registered_signers_by_role Current number of registered signers by role
# TYPE tso_core_registered_signers_by_role gauge
tso_core_registered_signers_by_role{role="Attestation"} 3
# HELP tso_core_registered_signer_info Registered signer labels
# TYPE tso_core_registered_signer_info gauge
tso_core_registered_signer_info{role="Attestation",public_key="02abc"} 1
tso_core_registered_signer_info{role="Attestation",public_key="03abc"} 1
# HELP tso_core_transactions_by_status Current in-memory TSO transaction count by status
# TYPE tso_core_transactions_by_status gauge
tso_core_transactions_by_status{status="collecting_attestation"} 1
tso_core_transactions_by_status{status="completed"} 4
# HELP tso_core_signer_transaction_events_total Counter for signer events
# TYPE tso_core_signer_transaction_events_total counter
tso_core_signer_transaction_events_total{signer_pubkey="02abc",event_type="signed"} 120
tso_core_signer_transaction_events_total{signer_pubkey="03abc",event_type="signed"} 118
tso_core_signer_transaction_events_total{signer_pubkey="02abc",event_type="response_timeout"} 1
# HELP tso_core_signer_response_latency_seconds Histogram of signature response latencies from signers
# TYPE tso_core_signer_response_latency_seconds histogram
tso_core_signer_response_latency_seconds_bucket{signer_pubkey="02abc",outcome="signed",le="0.1"} 4
tso_core_signer_response_latency_seconds_bucket{signer_pubkey="02abc",outcome="signed",le="0.5"} 90
tso_core_signer_response_latency_seconds_bucket{signer_pubkey="02abc",outcome="signed",le="1"} 118
tso_core_signer_response_latency_seconds_bucket{signer_pubkey="02abc",outcome="signed",le="+Inf"} 120
tso_core_signer_response_latency_seconds_sum{signer_pubkey="02abc",outcome="signed"} 54.2
tso_core_signer_response_latency_seconds_count{signer_pubkey="02abc",outcome="signed"} 120

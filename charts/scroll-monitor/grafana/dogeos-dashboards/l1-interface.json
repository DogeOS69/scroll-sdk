    {
      "datasource": {
        "type": "yesoreyeram-infinity-datasource",
        "uid": "dogeos-infinity"
      },
      "description": "Live WF transaction chain height read directly from the l1-interface eth_blockNumber JSON-RPC (not a Prometheus metric).",
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "id": 43,
      "options": {
        "textMode": "value",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "yesoreyeram-infinity-datasource",
            "uid": "dogeos-infinity"
          },
          "refId": "A",
          "type": "json",
          "source": "url",
          "format": "table",
          "parser": "uql",
          "url": "http://l1-interface:8545",
          "url_options": {
            "method": "POST",
            "headers": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body_type": "raw",
            "body_content_type": "application/json",
            "data": "{\"jsonrpc\":\"2.0\",\"method\":\"eth_blockNumber\",\"params\":[],\"id\":1}"
          },
          "uql": "parse-json | project \"height\"=parse_int(replace(\"result\", \"0x\", \"\"), 16)"
        }
      ],
      "title": "WF Transaction Chain (eth_blockNumber)",
      "type": "stat"
    },

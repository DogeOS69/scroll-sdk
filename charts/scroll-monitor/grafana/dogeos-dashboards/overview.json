    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "description": "Same L2 batch height as seen by each stage of the pipeline: eth-da-submitter publishes it, then it lands in Dogecoin DA and is recognized by the l1-interface and withdrawal-processor protocol state. The gap between the published line and the protocol-state lines is the DA settlement lag.",
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": { "fillOpacity": 6, "showPoints": "never", "lineWidth": 2 }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "showLegend": true, "calcs": ["lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 1 },
